# ============================================================
# JIP MF Recommendation Engine — Environment Variables
# Copy this file to .env.local and fill in actual values
# NEVER commit .env.local to git
# ============================================================

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/mf_engine
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/mf_engine  # For Alembic migrations

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Morningstar API Center ---
MORNINGSTAR_API_URL=https://apicenter.morningstar.com
MORNINGSTAR_USERNAME=                              # Email for API Center login
MORNINGSTAR_PASSWORD=                              # API Center password
MORNINGSTAR_ACCESS_CODE=                           # From Client Account > Authentication tab

# --- Authentication ---
JWT_SECRET=generate-a-random-32-char-string-here   # Min 32 chars
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Application ---
APP_NAME=JIP MF Recommendation Engine
APP_ENV=development                                # development / staging / production
APP_DEBUG=true
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000                  # Frontend URL(s), comma-separated

# --- Logging ---
LOG_LEVEL=INFO                                     # DEBUG / INFO / WARNING / ERROR
LOG_FORMAT=json                                    # json / console

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
